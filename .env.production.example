# === DATABASE ===
DB_USER=iadl_prod_user
DB_PASSWORD=<STRONG_RANDOM_PASSWORD>
DB_NAME=iadl_emis_prod
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public"

# === REDIS ===
REDIS_PASSWORD=<STRONG_RANDOM_PASSWORD>
REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"

# === AUTH ===
JWT_SECRET=<64_CHAR_RANDOM_SECRET>
JWT_EXPIRES_IN=7d
NEXTAUTH_SECRET=<64_CHAR_RANDOM_SECRET>
NEXTAUTH_URL=https://iadl.angazacenter.org

# === APP ===
NODE_ENV=production
API_PORT=3001
WEB_PORT=3000
API_URL=https://iadl.angazacenter.org/api/v1
NEXT_PUBLIC_API_URL=https://iadl.angazacenter.org/api/v1
WEB_URL=https://iadl.angazacenter.org

# === AWS ===
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=<IAM_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<IAM_SECRET_KEY>
AWS_S3_BUCKET=iadl-emis-prod-assets
AWS_COGNITO_USER_POOL_ID=af-south-1_XXXXXXX
AWS_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_EVENTBRIDGE_BUS=iadl-emis-prod-bus

# === M-PESA ===
MPESA_CONSUMER_KEY=<FROM_SAFARICOM_PORTAL>
MPESA_CONSUMER_SECRET=<FROM_SAFARICOM_PORTAL>
MPESA_SHORTCODE=174379
MPESA_PASSKEY=<FROM_SAFARICOM_PORTAL>
MPESA_CALLBACK_URL=https://iadl.angazacenter.org/api/v1/finance/mpesa/callback

# === SMS ===
AT_API_KEY=<AFRICAS_TALKING_API_KEY>
AT_USERNAME=iadl_emis
